{
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "ConnectionStrings": {
    "IoTSharp": "Data Source=.data/sonnetdb/iotsharp",
    "EventBusStore": "",
    "TelemetryStorage": "Data Source=.data/sonnetdb/telemetry;Measurement=TelemetryData;AutoCreate=true",
    "EventBusMQ": "",
    "BlobStorage": "sonnetdb://blob?bucket=iotsharp-blob-storage&connectionString=Data%20Source%3D.data%2Fsonnetdb%2Fobjects"
  },
  "JwtKey": "development-only-sonnetdb-profile-jwt-key-change-me-32-bytes-minimum",
  "JwtExpireHours": 24,
  "JwtIssuer": "IoTSharp.Net",
  "JwtAudience": "IoTSharp.Net",
  "DataBase": "SonnetDB",
  "TelemetryStorage": "SonnetDB",
  "CachingUseIn": "SonnetDB",
  "CachingUseSonnetDBConnectionString": "Data Source=.data/sonnetdb/cache",
  "CachingUseSonnetDBKeyspace": "cache",
  "CachingUseSonnetDBNamespace": "iotsharp",
  "EventBusStore": "InMemory",
  "EventBusMQ": "InMemory",
  "EventBus": "CAP",
  "ConsumerThreadCount": 10,
  "DbContextPoolSize": 256
}
