      "fieldPath": "metrics[machine_state].value",
      "sourceDataType": "enum",
      "polling": {
        "subscription": true
      },
      "mqtt": {
        "topic": "spBv1.0/site-alpha/DDATA/edge-node-01/filler-01",
        "namespaceStyle": "sparkplug",
        "payloadSchema": "sparkplugB",
        "qualityField": "metrics[machine_state].properties.quality",
        "valueField": "metrics[machine_state].value",
        "retain": false,
        "qos": 1,
        "sparkplugProfile": {
          "groupId": "site-alpha",
          "edgeNodeId": "edge-node-01",
          "deviceId": "filler-01",
          "metricName": "machine_state",
          "birth": {
            "enabled": true,
            "topic": "spBv1.0/site-alpha/DBIRTH/edge-node-01/filler-01",
            "metricName": "machine_state"
          },
          "death": {
            "enabled": true,
            "topic": "spBv1.0/site-alpha/DDEATH/edge-node-01/filler-01",
            "metricName": "machine_state"
          }
        }
      },
      "quality": {
        "status": "unknown",
        "source": "sparkplug-metric",
        "fieldPath": "metrics[machine_state].properties.quality",
        "metadata": {}
      },
      "options": {},
      "metadata": {
        "profile": "sparkplug-reserved"
      }
