        "semanticId": "boiler.01.supply_delta_temperature",
        "name": "supply_delta_temperature",
        "expression": "ref(\"boiler.01.supply_temperature\") - ref(\"boiler.01.return_temperature\")",
        "dependsOnSemanticIds": [
          "boiler.01.supply_temperature",
          "boiler.01.return_temperature"
        ],
        "quantity": {
          "quantityKind": "temperature",
          "name": "Temperature delta",
          "dimension": "thermodynamic-temperature",
          "standard": "ucum",
          "metadata": {}
        },
        "unit": {
          "code": "Cel",
          "displayName": "degree Celsius",
          "symbol": "C",
          "system": "ucum",
          "quantityKind": "temperature",
          "metadata": {}
        },
        "refreshPolicy": "onDependencyChange",
        "staleAfter": "00:00:10",
        "metadata": {}
      }
    ],
    "stateModels": [
      {
        "stateModelId": "state-boiler-01",
        "name": "Boiler operation state",
        "appliesToAssetId": "asset-boiler-01",
        "appliesToNodeId": "node-boiler-01",
        "defaultStateId": "standby",
        "mutuallyExclusive": true,
        "states": [
          {
            "stateId": "running",
            "name": "Running",
            "stateKind": "running",
            "condition": "ref(\"boiler.01.pump_run_command\") == true && ref(\"boiler.01.supply_delta_temperature\") > 5",
            "dependsOnSemanticIds": [
              "boiler.01.pump_run_command",
              "boiler.01.supply_delta_temperature"
            ],
            "dependsOnNodeIds": []
          },
          {
            "stateId": "standby",
            "name": "Standby",
            "stateKind": "standby",
            "dependsOnSemanticIds": [],
            "dependsOnNodeIds": []
          },
          {
            "stateId": "fault",
            "name": "Fault",
            "stateKind": "fault",
            "condition": "ref(\"boiler.01.supply_temperature\") > 95",
            "dependsOnSemanticIds": [
              "boiler.01.supply_temperature"
            ],
            "dependsOnNodeIds": []
          },
          {
            "stateId": "maintenance",
            "name": "Maintenance",
            "stateKind": "maintenance",
            "condition": "node(\"node-boiler-01\") == \"maintenance\"",
            "dependsOnSemanticIds": [],
            "dependsOnNodeIds": [
              "node-boiler-01"
            ]
          },
          {
            "stateId": "manual",
            "name": "Manual",
            "stateKind": "manual",
            "condition": "node(\"node-boiler-01\") == \"manual\"",
            "dependsOnSemanticIds": [],
            "dependsOnNodeIds": [
              "node-boiler-01"
            ]
          },
          {
            "stateId": "automatic",
            "name": "Automatic",
            "stateKind": "automatic",
            "condition": "node(\"node-boiler-01\") == \"automatic\"",
            "dependsOnSemanticIds": [],
            "dependsOnNodeIds": [
              "node-boiler-01"
            ]
          }
        ],
        "transitions": [
          {
            "fromStateId": "standby",
            "toStateId": "running",
            "condition": "ref(\"boiler.01.pump_run_command\") == true"
          },
          {
            "fromStateId": "running",
            "toStateId": "fault",
            "condition": "ref(\"boiler.01.supply_temperature\") > 95"
          }
        ],
        "metadata": {}
      }
    ],
    "alarms": [
      {
        "alarmId": "alarm-boiler-01-supply-temperature-high",
        "name": "Supply temperature high",
        "businessMeaning": "Supply water may overheat the downstream loop and should trigger operator intervention.",
        "severity": "major",
        "condition": "ref(\"boiler.01.supply_temperature\") > 90",
        "dependsOnSemanticIds": [
          "boiler.01.supply_temperature"
        ],
        "dependsOnNodeIds": [],
        "dependsOnStateModelIds": [
          "state-boiler-01"
        ],
        "duration": "00:00:30",
        "suppressionCondition": "state(\"state-boiler-01\") == \"maintenance\"",
        "recoveryCondition": "ref(\"boiler.01.supply_temperature\") <= 85",
        "metadata": {}
      },
      {
        "alarmId": "alarm-boiler-01-fault-state",
        "name": "Boiler fault state active",
        "businessMeaning": "The boiler state model indicates a fault and the unit should not be treated as available capacity.",
        "severity": "critical",
        "condition": "state(\"state-boiler-01\") == \"fault\"",
        "dependsOnSemanticIds": [
          "boiler.01.supply_temperature"
        ],
        "dependsOnNodeIds": [],
        "dependsOnStateModelIds": [
          "state-boiler-01"
        ],
        "duration": "00:00:05",
        "recoveryCondition": "state(\"state-boiler-01\") != \"fault\"",
        "metadata": {}
      }
    ],
    "controlPolicies": [
      {
        "controlPolicyId": "control-policy-pump-run",
        "name": "Pump run command policy",
        "appliesToSemanticIds": [
          "boiler.01.pump_run_command"
        ],
        "risk": "hazardous",
        "requiresApproval": true,
        "aiOperationMode": "recommendOnly",
        "allowAutomaticExecution": false,
        "approvalScope": "operator",
        "metadata": {}
      }
    ],
