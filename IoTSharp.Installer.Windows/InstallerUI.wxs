<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <UI>
      <TextStyle Id="WixUI_Font_Normal" FaceName="Tahoma" Size="8" />
      <TextStyle Id="WixUI_Font_Bigger" FaceName="Tahoma" Size="12" />
      <TextStyle Id="WixUI_Font_Title" FaceName="Tahoma" Size="9" Bold="yes" />

      <Property Id="DefaultUIFont" Value="WixUI_Font_Normal" />
      <Property Id="ARPNOMODIFY" Value="1" />

      <DialogRef Id="BrowseDlg" />
      <DialogRef Id="CancelDlg" />
      <DialogRef Id="DiskCostDlg" />
      <DialogRef Id="ErrorDlg" />
      <DialogRef Id="ExitDialog" />
      <DialogRef Id="FatalError" />
      <DialogRef Id="FilesInUse" />
      <DialogRef Id="InstallDirDlg" />
      <DialogRef Id="MaintenanceTypeDlg" />
      <DialogRef Id="MaintenanceWelcomeDlg" />
      <DialogRef Id="MsiRMFilesInUse" />
      <DialogRef Id="PrepareDlg" />
      <DialogRef Id="ProgressDlg" />
      <DialogRef Id="ResumeDlg" />
      <DialogRef Id="UserExit" />
      <DialogRef Id="VerifyReadyDlg" />
      <DialogRef Id="WelcomeDlg" />
      <DialogRef Id="DatabaseConfigDlg" />

      <Publish Dialog="ExitDialog" Control="Finish" Event="EndDialog" Value="Return" Order="999" />

      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="InstallDirDlg" Condition="NOT Installed" />
      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" Condition="Installed AND PATCH" />

      <Publish Dialog="InstallDirDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" />
      <Publish Dialog="InstallDirDlg" Control="ChangeFolder" Property="_BrowseProperty" Value="[WIXUI_INSTALLDIR]" Order="1" />
      <Publish Dialog="InstallDirDlg" Control="ChangeFolder" Event="SpawnDialog" Value="BrowseDlg" Order="2" />
      <Publish Dialog="InstallDirDlg" Control="Next" Event="CheckTargetPath" Value="[WIXUI_INSTALLDIR]" Order="1" />
      <Publish Dialog="InstallDirDlg" Control="Next" Event="SetTargetPath" Value="[WIXUI_INSTALLDIR]" Order="2" />
      <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="DatabaseConfigDlg" Order="3" />

      <Publish Dialog="BrowseDlg" Control="OK" Event="CheckTargetPath" Value="[WIXUI_INSTALLDIR]" Order="1" />
      <Publish Dialog="BrowseDlg" Control="OK" Event="SetTargetPath" Value="[_BrowseProperty]" Order="2" />
      <Publish Dialog="BrowseDlg" Control="OK" Event="EndDialog" Value="Return" Order="3" />

      <Publish Dialog="DatabaseConfigDlg" Control="Back" Event="NewDialog" Value="InstallDirDlg" />
      <Publish Dialog="DatabaseConfigDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" />

      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="DatabaseConfigDlg" Order="1" Condition="NOT Installed" />
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="MaintenanceTypeDlg" Order="2" Condition="Installed AND NOT PATCH" />
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" Order="3" Condition="Installed AND PATCH" />

      <Publish Dialog="MaintenanceWelcomeDlg" Control="Next" Event="NewDialog" Value="MaintenanceTypeDlg" />
      <Publish Dialog="MaintenanceTypeDlg" Control="RepairButton" Event="NewDialog" Value="VerifyReadyDlg" />
      <Publish Dialog="MaintenanceTypeDlg" Control="RemoveButton" Event="NewDialog" Value="VerifyReadyDlg" />
      <Publish Dialog="MaintenanceTypeDlg" Control="Back" Event="NewDialog" Value="MaintenanceWelcomeDlg" />
    </UI>

    <UIRef Id="WixUI_Common" />
  </Fragment>

  <Fragment>
    <UI>
      <ComboBox Property="IOTSHARP_DB_TEMPLATE">
        <ListItem Text="Sqlite (local file)" Value="Sqlite" />
        <ListItem Text="PostgreSQL" Value="PostgreSql" />
        <ListItem Text="MySQL" Value="MySql" />
        <ListItem Text="SQL Server" Value="SQLServer" />
        <ListItem Text="Oracle" Value="Oracle" />
        <ListItem Text="ClickHouse" Value="ClickHouse" />
        <ListItem Text="Cassandra" Value="Cassandra" />
      </ComboBox>

      <Dialog Id="DatabaseConfigDlg" Width="370" Height="270" Title="IoTSharp Database Setup">
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="Next" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="Back" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>

        <Control Id="Description" Type="Text" X="25" Y="23" Width="300" Height="15" Transparent="yes" NoPrefix="yes" Text="Choose a database template and fill in the connection settings used by the IoTSharp service." />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="200" Height="15" Transparent="yes" NoPrefix="yes" Text="Database Configuration" />
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="!(loc.InstallDirDlgBannerBitmap)" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

        <Control Id="TemplateLabel" Type="Text" X="20" Y="60" Width="110" Height="16" Text="Database template:" />
        <Control Id="TemplateCombo" Type="ComboBox" X="140" Y="58" Width="190" Height="16" Property="IOTSHARP_DB_TEMPLATE" ComboList="yes" Sorted="no" />

        <Control Id="TemplateHint" Type="Text" X="20" Y="80" Width="320" Height="22" Transparent="yes" NoPrefix="yes" Text="Sqlite uses the local file path below. Other templates use host, port, database, username, and password. Leaving port empty uses the template default." />

        <Control Id="HostLabel" Type="Text" X="20" Y="108" Width="110" Height="16" Text="Server / host:" />
        <Control Id="HostEdit" Type="Edit" X="140" Y="106" Width="190" Height="18" Property="IOTSHARP_DB_HOST" />

        <Control Id="PortLabel" Type="Text" X="20" Y="126" Width="110" Height="16" Text="Port:" />
        <Control Id="PortEdit" Type="Edit" X="140" Y="124" Width="80" Height="18" Property="IOTSHARP_DB_PORT" />

        <Control Id="DatabaseLabel" Type="Text" X="20" Y="144" Width="110" Height="16" Text="Database / service:" />
        <Control Id="DatabaseEdit" Type="Edit" X="140" Y="142" Width="190" Height="18" Property="IOTSHARP_DB_NAME" />

        <Control Id="UserLabel" Type="Text" X="20" Y="162" Width="110" Height="16" Text="Username:" />
        <Control Id="UserEdit" Type="Edit" X="140" Y="160" Width="190" Height="18" Property="IOTSHARP_DB_USER" />

        <Control Id="PasswordLabel" Type="Text" X="20" Y="180" Width="110" Height="16" Text="Password:" />
        <Control Id="PasswordEdit" Type="Edit" X="140" Y="178" Width="190" Height="18" Property="IOTSHARP_DB_PASSWORD" Password="yes" />

        <Control Id="SqlitePathLabel" Type="Text" X="20" Y="198" Width="110" Height="16" Text="Sqlite file path:" />
        <Control Id="SqlitePathEdit" Type="Edit" X="140" Y="196" Width="190" Height="18" Property="IOTSHARP_SQLITE_PATH" />

        <Control Id="Examples" Type="Text" X="20" Y="216" Width="320" Height="14" Transparent="yes" NoPrefix="yes" Text="Defaults: PostgreSQL 5432, MySQL 3306, SQL Server 1433, Oracle 1521, ClickHouse 8123, Cassandra 9042." />
      </Dialog>
    </UI>
  </Fragment>
</Wix>
