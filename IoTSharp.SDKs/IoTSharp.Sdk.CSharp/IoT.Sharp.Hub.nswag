ype\": \"string\",\r\n            \"format\": \"guid\"\r\n          },\r\n          \"devicename\": {\r\n            \"type\": \"string\",\r\n            \"nullable\": true\r\n          },\r\n          \"attrs\": {\r\n            \"type\": \"array\",\r\n            \"nullable\": true,\r\n            \"items\": {\r\n              \"$ref\": \"#/components/schemas/ModelAssetAttrItem\"\r\n            }\r\n          },\r\n          \"temps\": {\r\n            \"type\": \"array\",\r\n            \"nullable\": true,\r\n            \"items\": {\r\n              \"$ref\": \"#/components/schemas/ModelAssetAttrItem\"\r\n            }\r\n          }\r\n        }\r\n      },\r\n      \"ModelEditAssetAttrItem\": {\r\n        \"type\": \"object\",\r\n        \"additionalProperties\": false,\r\n        \"properties\": {\r\n          \"id\": {\r\n            \"type\": \"string\",\r\n            \"format\": \"guid\"\r\n          },\r\n          \"description\": {\r\n            \"type\": \"string\",\r\n            \"nullable\": true\r\n          },\r\n          \"name\": {\r\n            \"type\": \"string\",\r\n            \"nullable\": true\r\n          }\r\n        }\r\n      },\r\n      \"ApiResultOfListOfBlob\": {\r\n        \"allOf\": [\r\n          {\r\n            \"$ref\": \"#/components/schemas/ApiResult\"\r\n          },\r\n          {\r\n            \"type\": \"object\",\r\n            \"additionalProperties\": false,\r\n            \"properties\": {\r\n              \"data\": {\r\n                \"type\": \"array\",\r\n                \"nullable\": true,\r\n                \"items\": {\r\n                  \"$ref\": \"#/components/schemas/Blob\"\r\n                }\r\n              }\r\n            }\r\n          }\r\n        ]\r\n      },\r\n      \"Blob\": {\r\n        \"type\": \"object\",\r\n        \"description\": \"Blob item description\",\r\n        \"additionalProperties\": false,\r\n        \"properties\": {\r\n          \"kind\": {\r\n            \"description\": \"Gets the kind of item\",\r\n            \"oneOf\": [\r\n              {\r\n                \"$ref\": \"#/components/schemas/BlobItemKind\"\r\n              }\r\n            ]\r\n          },\r\n          \"isFolder\": {\r\n            \"type\": \"boolean\",\r\n            \"description\": \"Simply checks if kind of this item is Folder\"\r\n          },\r\n          \"isFile\": {\r\n            \"type\": \"boolean\",\r\n            \"description\": \"Simply checks if kind of this item is File\"\r\n          },\r\n          \"folderPath\": {\r\n            \"type\": \"string\",\r\n            \"description\": \"Gets the folder path containing this item\",\r\n            \"nullable\": true\r\n          },\r\n          \"name\": {\r\n            \"type\": \"string\",\r\n            \"description\": \"Gets the name of this blob, uniqueue within the folder. In most providers this is the same as file name.\",\r\n            \"nullable\": true\r\n          },\r\n          \"size\": {\r\n            \"type\": \"integer\",\r\n            \"description\": \"Blob size\",\r\n            \"format\": \"int64\",\r\n            \"nullable\": true\r\n          },\r\n          \"mD5\": {\r\n            \"type\": \"string\",\r\n            \"description\": \"MD5 content hash of the blob. Note that this property can be null if underlying storage has\\nno information about the hash, or it's very expensive to calculate it, for instance it would require\\ngetting a whole content of the blob to hash it.\",\r\n            \"nullable\": true\r\n          },\r\n          \"createdTime\": {\r\n            \"type\": \"string\",\r\n            \"description\": \"Creation time when known\",\r\n            \"format\": \"date-time\",\r\n            \"nullable\": true\r\n          },\r\n          \"lastModificationTime\": {\r\n            \"type\": \"string\",\r\n            \"description\": \"Last modification time when known\",\r\n            \"format\": \"date-time\",\r\n            \"nullable\": true\r\n          },\r\n          \"fullPath\": {\r\n            \"type\": \"string\",\r\n            \"description\": \"Gets full path to this blob which is a combination of folder path and blob name\",\r\n            \"nullable\": true\r\n          },\r\n          \"properties\": {\r\n            \"type\": \"object\",\r\n            \"description\": \"Custom provider-specific properties. Key names are case-insensitive.\",\r\n            \"nullable\": true,\r\n            \"additionalProperties\": {}\r\n          },\r\n          \"metadata\": {\r\n            \"type\": \"object\",\r\n            \"description\": \"User defined metadata. Key names are case-insensitive.\",\r\n            \"nullable\": true,\r\n            \"additionalProperties\": {\r\n              \"type\": \"string\"\r\n            }\r\n          },\r\n          \"tag\": {\r\n            \"nullable\": true\r\n          },\r\n          \"isRootFolder\": {\r\n            \"type\": \"boolean\",\r\n            \"description\": \"Returns true if this item is a folder and it's a root folder\"\r\n          }\r\n        }\r\n      },\r\n      \"BlobItemKind\": {\r\n        \"type\": \"integer\",\r\n        \"description\": \"Type of the blob item in the storage\",\r\n        \"x-enumNames\": [\r\n          \"File\",\r\n          \"Folder\"\r\n        ],\r\n        \"enum\": [\r\n          0,\r\n          1\r\n        ]\r\n      },\r\n      \"ApiResultOfDictionaryOfStringAndString\": {\r\n        \"allOf\": [\r\n          {\r\n            \"$ref\": \"#/components/schemas/ApiResult\"\r\n          },\r\n          {\r\n            \"type\": \"object\",\r\n            \"additionalProperties\": false,\r\n            \"properties\": {\r\n              \"data\": {\r\n                \"type\": \"object\",\r\n                \"nullable\": true,\r\n                \"additionalProperties\": {\r\n                  \"type\": \"string\"\r\n                }\r\n              }\r\n            }\r\n          }\r\n        ]\r\n      },\r\n      \"ApiResultOfModelCaptchaChallenge\": {\r\n        \"allOf\": [\r\n          {\r\n            \"$ref\": \"#/components/schemas/ApiResult\"\r\n          },\r\n          {\r\n            \"type\": \"object\",\r\n            \"additionalProperties\": false,\r\n            \"properties\": {\r\n              \"data\": {\r\n                \"nullable\": true,\r\n                \"oneOf\": [\r\n                  {\r\n                    \"$ref\": \"#/components/schemas/ModelCaptchaChallenge\"\r\n                  }\r\n                ]\r\n              }\r\n            }\r\n          }\r\n        ]\r\n      },\r\n      \"ModelCaptchaChallenge\": {\r\n        \"type\": \"object\",\r\n        \"additionalProperties\": false,\r\n        \"properties\": {\r\n          \"yheight\": {\r\n            \"type\": \"integer\",\r\n            \"format\": \"int32\"\r\n          },\r\n          \"smallImage\": {\r\n            \"type\": \"string\",\r\n            \"nullable\": true\r\n          },\r\n          \"bigImage\": {\r\n            \"type\": \"string\",\r\n            \"nullable\": true\r\n          }\r\n        }\r\n      },\r\n      \"ModelCaptchaVertify\": {\r\n        \"type\": \"object\",\r\n        \"additionalProperties\": false,\r\n        \"properties\": {\r\n          \"move\": {\r\n            \"type\": \"integer\",\r\n            \"format\": \"int32\"\r\n          },\r\n          \"action\": {\r\n            \"type\": \"array\",\r\n            \"nullable\": true,\r\n            \"items\": {\r\n              \"type\": \"integer\",\r\n              \"format\": \"int32\"\r\n            }\r\n          }\r\n        }\r\n      },\r\n      \"ApiResultOfCollectionTaskDto\": {\r\n        \"allOf\": [\r\n          {\r\n            \"$ref\": \"#/components/schemas/ApiResult\"\r\n          },\r\n          {\r\n            \"type\": \"object\",\r\n            \"additionalProperties\": false,\r\n            \"properties\": {\r\n              \"data\"