ionConnectionDto\": {\r\n        \"type\": \"object\",\r\n        \"additionalProperties\": false,\r\n        \"properties\": {\r\n          \"connectionKey\": {\r\n            \"type\": \"string\"\r\n          },\r\n          \"connectionName\": {\r\n            \"type\": \"string\"\r\n          },\r\n          \"protocol\": {\r\n            \"$ref\": \"#/components/schemas/CollectionProtocolType\"\r\n          },\r\n          \"transport\": {\r\n            \"type\": \"string\"\r\n          },\r\n          \"host\": {\r\n            \"type\": \"string\",\r\n            \"nullable\": true\r\n          },\r\n          \"port\": {\r\n            \"type\": \"integer\",\r\n            \"format\": \"int32\",\r\n            \"nullable\": true\r\n          },\r\n          \"serialPort\": {\r\n            \"type\": \"string\",\r\n            \"nullable\": true\r\n          },\r\n          \"timeoutMs\": {\r\n            \"type\": \"integer\",\r\n            \"format\": \"int32\"\r\n          },\r\n          \"retryCount\": {\r\n            \"type\": \"integer\",\r\n            \"format\": \"int32\"\r\n          },\r\n          \"protocolOptions\": {\r\n            \"nullable\": true\r\n          }\r\n        }\r\n      },\r\n      \"CollectionDeviceDto\": {\r\n        \"type\": \"object\",\r\n        \"additionalProperties\": false,\r\n        \"properties\": {\r\n          \"deviceKey\": {\r\n            \"type\": \"string\"\r\n          },\r\n          \"deviceName\": {\r\n            \"type\": \"string\"\r\n          },\r\n          \"enabled\": {\r\n            \"type\": \"boolean\"\r\n          },\r\n          \"externalKey\": {\r\n            \"type\": \"string\",\r\n            \"nullable\": true\r\n          },\r\n          \"protocolOptions\": {\r\n            \"nullable\": true\r\n          },\r\n          \"points\": {\r\n            \"type\": \"array\",\r\n            \"items\": {\r\n              \"$ref\": \"#/components/schemas/CollectionPointDto\"\r\n            }\r\n          }\r\n        }\r\n      },\r\n      \"CollectionPointDto\": {\r\n        \"type\": \"object\",\r\n        \"additionalProperties\": false,\r\n        \"properties\": {\r\n          \"pointKey\": {\r\n            \"type\": \"string\"\r\n          },\r\n          \"pointName\": {\r\n            \"type\": \"string\"\r\n          },\r\n          \"sourceType\": {\r\n            \"type\": \"string\"\r\n          },\r\n          \"address\": {\r\n            \"type\": \"string\"\r\n          },\r\n          \"rawValueType\": {\r\n            \"type\": \"string\"\r\n          },\r\n          \"length\": {\r\n            \"type\": \"integer\",\r\n            \"format\": \"int32\"\r\n          },\r\n          \"polling\": {\r\n            \"$ref\": \"#/components/schemas/PollingPolicyDto\"\r\n          },\r\n          \"transforms\": {\r\n            \"type\": \"array\",\r\n            \"items\": {\r\n              \"$ref\": \"#/components/schemas/ValueTransformDto\"\r\n            }\r\n          },\r\n          \"mapping\": {\r\n            \"$ref\": \"#/components/schemas/PlatformMappingDto\"\r\n          },\r\n          \"protocolOptions\": {\r\n            \"nullable\": true\r\n          }\r\n        }\r\n      },\r\n      \"PollingPolicyDto\": {\r\n        \"type\": \"object\",\r\n        \"additionalProperties\": false,\r\n        \"properties\": {\r\n          \"readPeriodMs\": {\r\n            \"type\": \"integer\",\r\n            \"format\": \"int32\"\r\n          },\r\n          \"group\": {\r\n            \"type\": \"string\",\r\n            \"nullable\": true\r\n          }\r\n        }\r\n      },\r\n      \"ValueTransformDto\": {\r\n        \"type\": \"object\",\r\n        \"additionalProperties\": false,\r\n        \"properties\": {\r\n          \"transformType\": {\r\n            \"$ref\": \"#/components/schemas/CollectionTransformType\"\r\n          },\r\n          \"order\": {\r\n            \"type\": \"integer\",\r\n            \"format\": \"int32\"\r\n          },\r\n          \"parameters\": {\r\n            \"nullable\": true\r\n          }\r\n        }\r\n      },\r\n      \"CollectionTransformType\": {\r\n        \"type\": \"string\",\r\n        \"description\": \"\",\r\n        \"x-enumNames\": [\r\n          \"Scale\",\r\n          \"Offset\",\r\n          \"Expression\",\r\n          \"EnumMap\",\r\n          \"BitExtract\",\r\n          \"WordSwap\",\r\n          \"ByteSwap\",\r\n          \"Clamp\",\r\n          \"DefaultOnError\"\r\n        ],\r\n        \"enum\": [\r\n          \"Scale\",\r\n          \"Offset\",\r\n          \"Expression\",\r\n          \"EnumMap\",\r\n          \"BitExtract\",\r\n          \"WordSwap\",\r\n          \"ByteSwap\",\r\n          \"Clamp\",\r\n          \"DefaultOnError\"\r\n        ]\r\n      },\r\n      \"PlatformMappingDto\": {\r\n        \"type\": \"object\",\r\n        \"additionalProperties\": false,\r\n        \"properties\": {\r\n          \"targetType\": {\r\n            \"$ref\": \"#/components/schemas/CollectionTargetType\"\r\n          },\r\n          \"targetName\": {\r\n            \"type\": \"string\"\r\n          },\r\n          \"valueType\": {\r\n            \"$ref\": \"#/components/schemas/CollectionValueType\"\r\n          },\r\n          \"displayName\": {\r\n            \"type\": \"string\",\r\n            \"nullable\": true\r\n          },\r\n          \"unit\": {\r\n            \"type\": \"string\",\r\n            \"nullable\": true\r\n          },\r\n          \"group\": {\r\n            \"type\": \"string\",\r\n            \"nullable\": true\r\n          }\r\n        }\r\n      },\r\n      \"CollectionTargetType\": {\r\n        \"type\": \"string\",\r\n        \"description\": \"\",\r\n        \"x-enumNames\": [\r\n          \"Telemetry\",\r\n          \"Attribute\",\r\n          \"AlarmInput\",\r\n          \"CommandFeedback\"\r\n        ],\r\n        \"enum\": [\r\n          \"Telemetry\",\r\n          \"Attribute\",\r\n          \"AlarmInput\",\r\n          \"CommandFeedback\"\r\n        ]\r\n      },\r\n      \"CollectionValueType\": {\r\n        \"type\": \"string\",\r\n        \"description\": \"\",\r\n        \"x-enumNames\": [\r\n          \"Boolean\",\r\n          \"Int32\",\r\n          \"Int64\",\r\n          \"Double\",\r\n          \"Decimal\",\r\n          \"String\",\r\n          \"Enum\",\r\n          \"Json\"\r\n        ],\r\n        \"enum\": [\r\n          \"Boolean\",\r\n          \"Int32\",\r\n          \"Int64\",\r\n          \"Double\",\r\n          \"Decimal\",\r\n          \"String\",\r\n          \"Enum\",\r\n          \"Json\"\r\n        ]\r\n      },\r\n      \"ReportPolicyDto\": {\r\n        \"type\": \"object\",\r\n        \"additionalProperties\": false,\r\n        \"properties\": {\r\n          \"defaultTrigger\": {\r\n            \"$ref\": \"#/components/schemas/ReportTriggerType\"\r\n          },\r\n          \"deadband\": {\r\n            \"type\": \"number\",\r\n            \"format\": \"double\",\r\n            \"nullable\": true\r\n          },\r\n          \"includeQuality\": {\r\n            \"type\": \"boolean\"\r\n          },\r\n          \"includeTimestamp\": {\r\n            \"type\": \"boolean\"\r\n          }\r\n        }\r\n      },\r\n      \"ReportTriggerType\": {\r\n        \"type\": \"string\",\r\n        \"description\": \"\",\r\n        \"x-enumNames\": [\r\n          \"Always\",\r\n          \"OnChange\",\r\n          \"Deadband\",\r\n          \"Interval\",\r\n          \"QualityChange\"\r\n        ],\r\n        \"enum\": [\r\n          \"Always\",\r\n          \"OnChange\",\r\n          \"Deadband\",\r\n          \"Interval\",\r\n          \"QualityChange\"\r\n        ]\r\n      },\r\n      \"ApiResultOfTaskPreviewResponseDto\": {\r\n        \"allOf\": [\r\n          {\r\n            \"$ref\": \"#/components/schemas/ApiResult\"\r\n          },\r\n          {\r\n            \"type\": \"object\",\r\n            \"additionalProperties\"